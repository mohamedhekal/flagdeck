{
    "name": "hekal/flagdeck",
    "description": "Production-ready feature flags, percentage rollouts, and tenant targeting for Laravel",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "feature-flags",
        "feature-toggles",
        "rollouts",
        "multi-tenancy",
        "saas",
        "experimentation"
    ],
    "authors": [
        {
            "name": "Mohamed Hekal",
            "email": "mohamed@hekal.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/cache": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "laravel/pint": "^1.18",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Hekal\\FlagDeck\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hekal\\FlagDeck\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hekal\\FlagDeck\\FlagDeckServiceProvider"
            ],
            "aliases": {
                "FlagDeck": "Hekal\\FlagDeck\\Facades\\FlagDeck"
            }
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse --memory-limit=512M",
        "format": "pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
